# ============================================================================
# expected/ IS SCANNED — the whole point of this project is generating
# PHPStan-max-level code. If expected/ has errors, the GENERATOR is broken.
# Fix the generator, regenerate expected/, never exclude it from PHPStan.
# ============================================================================

includes:
    - ../vendor/lts/php-qa-ci/configDefaults/generic/phpstan.neon

rules:
    # Project-specific rules
    - QaConfig\PHPStan\Rules\ForbidInlineVarAnnotationRule
    - QaConfig\PHPStan\Rules\ForbidAssertCallRule
    - QaConfig\PHPStan\Rules\ForbidGeneratedAssertRule
    - QaConfig\PHPStan\Rules\RequireStrictComparisonRule
    # php-qa-ci rules — security
    - LTS\PHPQA\PHPStan\Rules\ForbidDangerousFunctionsRule
    # php-qa-ci rules — error handling
    - LTS\PHPQA\PHPStan\Rules\ForbidEmptyCatchBlockRule
    - LTS\PHPQA\PHPStan\Rules\ForbidSilentCatchRule
    # php-qa-ci rules — type safety
    - LTS\PHPQA\PHPStan\Rules\ForbidEmptyLanguageConstructRule
    # php-qa-ci rules — PHP 8.4 compatibility
    - LTS\PHPQA\PHPStan\Rules\ForbidDeprecatedSerializableRule
    - LTS\PHPQA\PHPStan\Rules\ForbidNewDateTimeRule
    # php-qa-ci rules — code quality
    - LTS\PHPQA\PHPStan\Rules\ForbidInlinePhpstanIgnoreRule
    - LTS\PHPQA\PHPStan\Rules\ForbidNestedTernaryRule
    - LTS\PHPQA\PHPStan\Rules\RequireDeclareStrictTypesRule
    - LTS\PHPQA\PHPStan\Rules\RequireTypeSuffixRule

parameters:
    scanDirectories:
        - ../qaConfig/PHPStan/Rules
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # Runtime template traits in Generator/Runtime/data/ are scanned by PHPStan
        # (per CLAUDE.md, to validate \-prefixed FQCN usage and PHP correctness)
        # but never loaded as classes — they are parsed as templates and copied
        # verbatim into generated code under arbitrary destination namespaces.
        # The trait.unused warning is therefore a structural false positive.
        - identifier: trait.unused
        # Naming conventions: Jane PHP upstream defines runtime template traits and
        # interfaces (CheckArray, ApiException, ClientException, ServerException,
        # AuthenticationPlugin, CustomQueryResolver, Endpoint) without the Trait/
        # Interface suffix. These templates are copied verbatim into every generated
        # SDK under their unsuffixed names — renaming them would be a breaking change
        # to the public API of every SDK ever generated by this tool. The same applies
        # to a handful of internal generator traits (ClassGenerator, NormalizerGenerator
        # etc.) where the trait name forms part of the generated class structure.
        # Suppress until a coordinated major-version rename.
        - identifier: phpqaci.traitSuffix
        - identifier: phpqaci.interfaceSuffix
