# ============================================================================
# expected/ IS SCANNED — the whole point of this project is generating
# PHPStan-max-level code. If expected/ has errors, the GENERATOR is broken.
# Fix the generator, regenerate expected/, never exclude it from PHPStan.
# ============================================================================

includes:
    - ../vendor/lts/php-qa-ci/configDefaults/generic/phpstan.neon
    - ../vendor/lts/php-qa-ci/rules-optional.neon

rules:
    # Project-specific rules
    - QaConfig\PHPStan\Rules\ForbidInlineVarAnnotationRule
    - QaConfig\PHPStan\Rules\ForbidAssertCallRule
    - QaConfig\PHPStan\Rules\ForbidGeneratedAssertRule
    - QaConfig\PHPStan\Rules\ForbidGeneratorImportInOutputRule
    - QaConfig\PHPStan\Rules\RequireStrictComparisonRule

parameters:
    scanDirectories:
        - ../qaConfig/PHPStan/Rules
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # Runtime template traits in Generator/Runtime/data/ are scanned by PHPStan
        # (per CLAUDE.md, to validate \-prefixed FQCN usage and PHP correctness)
        # but never loaded as classes — they are parsed as templates and copied
        # verbatim into generated code under arbitrary destination namespaces.
        # The trait.unused warning is therefore a structural false positive.
        - identifier: trait.unused
        # Generated SDK fixtures (expected/) carry credential-named parameters
        # (password, clientSecret, webhookSecret, secretKey, …) lifted verbatim from
        # third-party API specs (github, twitter, oauth flows). The native
        # #[\SensitiveParameter] redaction attribute can only be emitted by the
        # GENERATOR — it cannot be hand-added to expected/ output, which is regenerated
        # wholesale and byte-compared. A rule that requires a hand-added attribute
        # therefore cannot be satisfied here, so it is exempted for generated fixtures.
        # (Emitting #[\SensitiveParameter] from the generator for genuine-credential
        # properties is a tracked future enhancement; these fixtures are never run as
        # production credential-handling code.)
        - identifier: phpqaci.requireSensitiveParameterAttribute
          path: ../src/Component/OpenApi3/Tests/fixtures/*/expected/*
