# ============================================================================
# expected/ IS SCANNED — the whole point of this project is generating
# PHPStan-max-level code. If expected/ has errors, the GENERATOR is broken.
# Fix the generator, regenerate expected/, never exclude it from PHPStan.
# ============================================================================

includes:
    - ../vendor/lts/php-qa-ci/configDefaults/generic/phpstan.neon

rules:
    # Project-specific rules
    - QaConfig\PHPStan\Rules\ForbidInlineVarAnnotationRule
    - QaConfig\PHPStan\Rules\ForbidAssertCallRule
    - QaConfig\PHPStan\Rules\ForbidGeneratedAssertRule
    - QaConfig\PHPStan\Rules\RequireStrictComparisonRule
    # php-qa-ci rules — security
    - LTS\PHPQA\PHPStan\Rules\ForbidDangerousFunctionsRule
    # php-qa-ci rules — error handling
    - LTS\PHPQA\PHPStan\Rules\ForbidEmptyCatchBlockRule
    - LTS\PHPQA\PHPStan\Rules\ForbidSilentCatchRule
    # php-qa-ci rules — type safety
    - LTS\PHPQA\PHPStan\Rules\ForbidEmptyLanguageConstructRule
    # php-qa-ci rules — PHP 8.4 compatibility
    - LTS\PHPQA\PHPStan\Rules\ForbidDeprecatedSerializableRule
    - LTS\PHPQA\PHPStan\Rules\ForbidNewDateTimeRule
    # php-qa-ci rules — code quality
    - LTS\PHPQA\PHPStan\Rules\ForbidInlinePhpstanIgnoreRule
    - LTS\PHPQA\PHPStan\Rules\RequireDeclareStrictTypesRule

parameters:
    scanDirectories:
        - ../qaConfig/PHPStan/Rules
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # PHPUnit assertion methods — static methods called as instance methods ($this->assertXxx).
        # Stylistic choice; rewriting every test to self::assertX would be churn for zero benefit.
        - identifier: staticMethod.dynamicCall
        # new static() in factory methods — intentional for inheritance support
        - identifier: new.static
        # issue-669 fixture: model has a `flags` property which collides with
        # ArrayObject::getFlags(): int. The model emits getFlags(): ?int which
        # is not covariant. This is a real generator template bug — when a
        # property name collides with an ArrayObject built-in method, the
        # generator should rename or skip the accessor. Until that's fixed,
        # the issue-669 fixture must ignore this identifier.
        -
            identifier: method.childReturnType
            path: ../src/Component/OpenApi3/Tests/fixtures/issue-669/expected/Model/*
        # (string) cast on foreach key over ArrayObject<string, mixed> — PHPStan thinks the cast
        # is useless because the @template says string, but PHP COERCES numeric-string keys to int
        # when stored in ArrayObject/array, so the cast is genuinely needed at runtime under
        # strict_types. Removing it would TypeError on numeric-string keys.
        - identifier: cast.useless
        # Runtime template traits only used in generated code, not scanned source
        - identifier: trait.unused
        # OpenApi3 JsonSchema normalizers — auto-generated by NormalizerGenerator.
        # 49 errors across ~20 normalizer files. The errors break down into distinct
        # root causes, all of which are template bugs that must be fixed in
        # src/Component/GeneratorCore/Generator/Normalizer/ and related generators:
        #
        #   Pattern A: ArrayObject<*NEVER*, *NEVER*> from empty `new ArrayObject()`.
        #     The generator emits `$values = new ArrayObject([], ArrayObject::ARRAY_AS_PROPS);`
        #     then populates it. PHPStan can't infer the template params from the
        #     populate loop. Fix: emit `new ArrayObject([], ArrayObject::ARRAY_AS_PROPS, ...)`
        #     with an explicit @var array<string, TargetType> annotation on the line,
        #     or construct with a typed initial array.
        #
        #   Pattern B: Raw $data['key'] passed to typed setters expecting string/bool.
        #     Fix: wrap with TypeValidator::assertString/assertBool/etc. in the
        #     emitted denormalize() template.
        #
        #   Pattern C: `is_object($value)` guards against $data values which are
        #     already `mixed`. PHPStan narrows `mixed` minus `object` to `mixed`,
        #     so the guard appears redundant. Fix: the emitted `is_object` check
        #     is genuinely pointless when $value is from JSON — remove it from
        #     the template or guard earlier with array shape knowledge.
        #
        #   Pattern D: ArrayObject<string, X> given to array<string, Y>|null setter.
        #     The ArrayObject has the right template params but the setter expects
        #     a plain array. Fix: emit `iterator_to_array($values)` or change the
        #     model setters to accept ArrayObject too.
        #
        #   Pattern E: JaneObjectNormalizer::denormalize returns mixed; the cache
        #     property type is too narrow. Fix: rework the generic type annotations
        #     in the runtime JaneObjectNormalizer template.
        #
        # Until the above are fixed in the generator templates, these ignores must
        # remain in place. Do NOT suppress these in service code — fix the templates.
        -
            identifier: function.impossibleType
            path: ../src/Component/OpenApi3/JsonSchema/Normalizer/*
        -
            identifier: argument.type
            path: ../src/Component/OpenApi3/JsonSchema/Normalizer/*
        -
            identifier: offsetAssign.valueType
            path: ../src/Component/OpenApi3/JsonSchema/Normalizer/*
        -
            identifier: assign.propertyType
            path: ../src/Component/OpenApi3/JsonSchema/Normalizer/*
